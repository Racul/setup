" 줄 번호 표시
set number

" 자동 들여쓰기
set autoindent
set smartindent

" 탭 대신 공백 사용
set expandtab
set tabstop=4
set shiftwidth=4

" 검색 관련 설정
set ignorecase
set smartcase
set hlsearch
set incsearch

" 마우스 사용 가능
set mouse=a

" 커서가 위치한 줄 강조
set cursorline

" 키 매핑 설정
inoremap jj <Esc>
nnoremap <C-s> :w<CR>
nnoremap <C-q> :wq<CR>

" 실행 속도 개선
set timeoutlen=500

